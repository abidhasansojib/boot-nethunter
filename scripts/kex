#!/bin/bash

# --- 1. Colors & Design System ---
RED='\033[1;31m'
BLUE='\033[1;34m'
RESET='\033[0m'

# --- 2. Banner Function ---
print_banner() {
    clear
    echo -e "${BLUE}====================================================${RESET}"
    echo -e "${BLUE}    _  _  _  _   _             _               ${RESET}"
    echo -e "${BLUE}   | \\| || |_| | |_  _ _ _  _| |_  ___ _ _    ${RESET}"
    echo -e "${BLUE}   | .  ||  _| | . || | | || . | || . | | |    ${RESET}"
    echo -e "${BLUE}   |_|\\_||___| |_|_||_____||___|_||  _|___|    ${RESET}"
    echo -e "${BLUE}                                  |_|          ${RESET}"
    echo -e "        ${RED}⚡ Kali NetHunter KeX Desktop Manager ⚡${RESET}"
    echo -e "${BLUE}====================================================${RESET}"
}

# --- 3. Usage Help Function ---
show_usage() {
    print_banner
    echo -e "${BLUE}Usage Options:${RESET}"
    echo -e "  kex          - Start KeX server as normal user (kali)"
    echo -e "  kex -r       - Start KeX server as root user"
    echo -e "  kex kill     - Stop all running KeX server instances"
    echo -e "  kex stop     - Stop all running KeX server instances (alias)"
    echo ""
}

# --- 4. VNC Kill function ---
kill_vnc() {
    print_banner
    echo -e "${BLUE}[*] Stopping all VNC server instances...${RESET}"
    echo ""
    
    local displays
    displays=$( (
        find /home/*/.vnc/ /root/.vnc/ -name "*.pid" 2>/dev/null | xargs -r -n1 basename 2>/dev/null | sed 's/\.pid//' | sed 's/.*:/:/'
        find /tmp/.X11-unix/ -name "X*" 2>/dev/null | sed 's/.*X/:/'
        find /tmp/ -name ".X*-lock" 2>/dev/null | sed -E 's/.*\.X([0-9]+)-lock/:\1/'
    ) | sort -u )
    
    if [ -n "$displays" ]; then
        for display in $displays; do
            echo -e "${BLUE}[-] Stopping display $display...${RESET}"
            vncserver -kill "$display" >/dev/null 2>&1
            sudo -u kali vncserver -kill "$display" >/dev/null 2>&1
            sudo -u root vncserver -kill "$display" >/dev/null 2>&1
        done
    else
        echo -e "${BLUE}[i] No active displays found running.${RESET}"
    fi

    # Force kill any remaining processes
    pkill -f Xvnc >/dev/null 2>&1
    pkill -f vncserver >/dev/null 2>&1
    
    # Clean up lock files and sockets to prevent startup issues
    rm -f /tmp/.X*-lock /tmp/.X11-unix/X* >/dev/null 2>&1
    rm -f /home/*/.vnc/*.pid /home/*/.vnc/*.log /root/.vnc/*.pid /root/.vnc/*.log >/dev/null 2>&1
    
    echo ""
    echo -e "${BLUE}✓ All VNC servers stopped and sockets cleaned up successfully!${RESET}"
    echo ""
}

# --- 5. Check for kill command ---
if [ "$1" = "kill" ] || [ "$1" = "stop" ] || { [ "$1" = "-r" ] && [ "$2" = "kill" ]; } || { [ "$1" = "-r" ] && [ "$2" = "stop" ]; }; then
    kill_vnc
    exit 0
fi

# --- 6. Check and Install Desktop/VNC ---
if ! command -v vncserver >/dev/null 2>&1 || [ ! -d /usr/share/xsessions ]; then
    echo -ne "\033]0;Installing XFCE Desktop\007"
    print_banner
    echo -e "${RED}[!] Warning: XFCE Desktop or VNC Server is not installed!${RESET}"
    echo -e "${BLUE}[*] Preparing to install dependencies (kali-desktop-xfce, tigervnc, dbus)...${RESET}"
    echo -e "${BLUE}[*] Running apt update & install...${RESET}\n"
    
    apt update && apt install -y kali-desktop-xfce tigervnc-standalone-server dbus-x11
    apt clean
    
    echo -e "\n${BLUE}✓ Setup complete! Please run 'kex' again to launch the server.${RESET}"
    exit 0
fi

# --- 7. Determine Execution Mode (-r or normal) ---
RUN_AS_ROOT=false

if [ "$1" == "-r" ]; then
    RUN_AS_ROOT=true
elif [ -n "$1" ]; then
    show_usage
    exit 1
fi

# --- 8. Password Setup and Server Launch logic ---
if [ "$RUN_AS_ROOT" = true ]; then
    # --- ROOT MODE (kex -r) ---
    
    print_banner
    echo -e "${BLUE}[*] Mode: ${RED}Root User (kex -r)${RESET}"
    echo ""

    # Check if root password file exists
    if [ ! -f /root/.vnc/passwd ] && [ ! -f /root/.config/tigervnc/passwd ]; then
        echo -ne "\033]0;Setting up KeX Server Password\007"
        [ -f ~/.vnc/xstartup ] && chmod +x ~/.vnc/xstartup
        echo -e "${RED}[!] VNC password file not found. Let's create one now.${RESET}"
        echo -e "${BLUE}[*] Please enter your new VNC server password below:${RESET}\n"
        
        if [ "root" == "root" ]; then 
            if [ ! -d /root/.config/tigervnc ]; then mkdir -p -m 0777 /root/.config/tigervnc; fi
            sudo -u root vncpasswd
            if [ ! -f ~/.vnc/passwd ]; then cp -rf ~/.config/tigervnc/passwd ~/.vnc/; fi
        else 
            user_uid=$(id -u root)
            if [ "$user_uid" -eq 100000 ] || [ "$user_uid" -eq 9000 ]; then 
                if [ ! -d /home/root/.config/tigervnc ]; then mkdir -p -m 0777 /home/root/.config/tigervnc; fi
                sudo -u root vncpasswd
                if [ ! -f /home/root/.vnc/passwd ]; then cp -rf /home/root/.config/tigervnc/passwd /home/root/.vnc/; fi
            fi
        fi
        echo ""
        echo -e "${BLUE}✓ VNC Password configured successfully.${RESET}"
        sleep 1
        print_banner
        echo -e "${BLUE}[*] Mode: ${RED}Root User (kex -r)${RESET}"
        echo ""
    fi

    # Start Root server
    echo -ne "\033]0;Starting KeX Server\007"
    echo -e "${BLUE}[*] Starting VNC server on display :1...${RESET}"
    
    export HOME=/root
    export USER=root
    sudo -u root LD_PRELOAD=/usr/lib/aarch64-linux-gnu/libgcc_s.so.1 nohup vncserver :1 -localhost yes -name "NetHunter KeX" >/dev/null 2>&1 </dev/null
    
    if [ $? -eq 0 ]; then
        echo -e "${BLUE}✓ NetHunter KeX Server started successfully as root!${RESET}"
        echo -e "\n${BLUE}Connection details:${RESET}"
        echo -e "  - Host: 127.0.0.1 (localhost)"
        echo -e "  - Port: 5901 (Display :1)"
        echo -e "  - VNC Client settings: Address ${BLUE}127.0.0.1:5901${RESET} or port ${BLUE}5901${RESET}"
        echo ""
    else
        echo -e "${RED}❌ Failed to start the server. It might already be running.${RESET}"
        echo -e "${RED}[!] Run 'kex kill' first if you need to restart the session.${RESET}"
    fi

else
    # --- KALI USER MODE (kex) ---
    
    print_banner
    echo -e "${BLUE}[*] Mode: Normal User (kali)${RESET}"
    echo ""

    # Check if kali user password file exists
    if [ ! -f /home/kali/.vnc/passwd ] && [ ! -f /home/kali/.config/tigervnc/passwd ]; then
        echo -ne "\033]0;Setting up KeX Server Password\007"
        [ -f ~/.vnc/xstartup ] && chmod +x ~/.vnc/xstartup
        echo -e "${RED}[!] VNC password file not found. Let's create one now.${RESET}"
        echo -e "${BLUE}[*] Please enter your new VNC server password below:${RESET}\n"
        
        if [ "kali" == "root" ]; then 
            if [ ! -d /root/.config/tigervnc ]; then mkdir -p -m 0777 /root/.root/.config/tigervnc; fi
            sudo -u root vncpasswd
            if [ ! -f ~/.vnc/passwd ]; then cp -rf ~/.config/tigervnc/passwd ~/.vnc/; fi
        else 
            user_uid=$(id -u kali)
            if [ "$user_uid" -eq 100000 ] || [ "$user_uid" -eq 9000 ]; then 
                if [ ! -d /home/kali/.config/tigervnc ]; then mkdir -p -m 0777 /home/kali/.config/tigervnc; fi
                sudo -u kali vncpasswd
                if [ ! -f /home/kali/.vnc/passwd ]; then cp -rf /home/kali/.config/tigervnc/passwd /home/kali/.vnc/; fi
            fi
        fi
        echo ""
        echo -e "${BLUE}✓ VNC Password configured successfully.${RESET}"
        sleep 1
        print_banner
        echo -e "${BLUE}[*] Mode: Normal User (kali)${RESET}"
        echo ""
    fi

    # Start Kali server
    echo -ne "\033]0;Starting KeX Server\007"
    echo -e "${BLUE}[*] Starting VNC server on display :1...${RESET}"
    
    export HOME=/home/kali
    export USER=kali
    sudo -u kali LD_PRELOAD=/usr/lib/aarch64-linux-gnu/libgcc_s.so.1 nohup vncserver :1 -localhost yes -name "NetHunter KeX" >/dev/null 2>&1 </dev/null
    
    if [ $? -eq 0 ]; then
        echo -e "${BLUE}✓ NetHunter KeX Server started successfully!${RESET}"
        echo -e "\n${BLUE}Connection details:${RESET}"
        echo -e "  - Host: 127.0.0.1 (localhost)"
        echo -e "  - Port: 5901 (Display :1)"
        echo -e "  - VNC Client settings: Address ${BLUE}127.0.0.1:5901${RESET} or port ${BLUE}5901${RESET}"
        echo ""
    else
        echo -e "${RED}❌ Failed to start the server. It might already be running.${RESET}"
        echo -e "${RED}[!] Run 'kex kill' first if you need to restart the session.${RESET}"
    fi
fi
